{
  "version": 3,
  "cmakeMinimumRequired": { "major": 4, "minor": 1, "patch": 0 },
  "configurePresets": [
    {
      "name": "Windows-VisualStudio",
      "displayName": "Windows (Visual Studio)",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/Intermediate/Windows-VisualStudio",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CONFIGURATION_TYPES": "Debug;RelWithDebInfo;Release",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Windows-Ninja",
      "hidden": true,
      "generator": "Ninja",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_FLAGS": "/std:c++20"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Windows-Ninja-Debug",
      "displayName": "Windows (Ninja) Debug",
      "inherits": "Windows-Ninja",
      "binaryDir": "${sourceDir}/Intermediate/Windows-Ninja/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Debug",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Debug",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Debug"
      }
    },
    {
      "name": "Windows-Ninja-RelWithDebInfo",
      "displayName": "Windows (Ninja) RelWithDebInfo",
      "inherits": "Windows-Ninja",
      "binaryDir": "${sourceDir}/Intermediate/Windows-Ninja/RelWithDebInfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/RelWithDebInfo",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/RelWithDebInfo",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/RelWithDebInfo"
      }
    },
    {
      "name": "Windows-Ninja-Release",
      "displayName": "Windows (Ninja) Release",
      "inherits": "Windows-Ninja",
      "binaryDir": "${sourceDir}/Intermediate/Windows-Ninja/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Release",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Release",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/Binaries/Windows/Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "Windows-VisualStudio-Debug",          "configurePreset": "Windows-VisualStudio", "configuration": "Debug" },
    { "name": "Windows-VisualStudio-RelWithDebInfo", "configurePreset": "Windows-VisualStudio", "configuration": "RelWithDebInfo" },
    { "name": "Windows-VisualStudio-Release",        "configurePreset": "Windows-VisualStudio", "configuration": "Release" },
    { "name": "Windows-Ninja-Debug",                 "configurePreset": "Windows-Ninja-Debug" },
    { "name": "Windows-Ninja-RelWithDebInfo",        "configurePreset": "Windows-Ninja-RelWithDebInfo" },
    { "name": "Windows-Ninja-Release",               "configurePreset": "Windows-Ninja-Release" }
  ]
}